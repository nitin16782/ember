# Core
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=mysql://user:pass@localhost:3306/ember_dev

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_ACCESS_TOKEN_TTL=900          # seconds (15 min)
JWT_REFRESH_TOKEN_TTL=2592000     # seconds (30 days)
BCRYPT_ROUNDS=12

# Cloudflare R2 (Prompt 6)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ember-dev
R2_PUBLIC_URL=

# MSG91 — SMS / OTP (shared defaults; Auth Key is the only required field)
MSG91_AUTH_KEY=
MSG91_DEFAULT_COUNTRY_CODE=91
MSG91_OTP_EXPIRY_MINUTES=10
MSG91_OTP_LENGTH=6

# Optional — only set in Phase 7 when DLT-approved templates exist
# MSG91_TEMPLATE_ID_OTP=
# MSG91_SENDER_ID=FIRBRK

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=ember@firebrick.one
RESEND_FROM_NAME=Ember by Firebrick

# Hostnames (production)
STAFF_HOSTNAME=app.firebrick.one
API_HOSTNAME=api.firebrick.one
OWNER_HOSTNAME=clients.firebrick.one

# Scheduled jobs (Prompt 7 — node-cron)
CRON_SHARED_SECRET=
